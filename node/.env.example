# Puerto en que escucha el servidor (opcional, default: 3000)
PORT=3000

# Clave de autenticación requerida en todos los endpoints como header:
#   X-Api-Key: <valor>
# Genera un valor seguro con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=

# Credenciales SII para los endpoints /api/RCV/compras y /api/RCV/ventas
# Formato RUT: sin puntos, con guión y dígito verificador (ej: 76284413-3)
SII_RUT=
SII_PASS=
